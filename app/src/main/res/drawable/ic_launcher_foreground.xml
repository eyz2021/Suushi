<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- 日式极简：汉字「枚」 (Mai) -->
    <!-- 使用极细线条绘制，体现高级感与洗练 -->

    <group android:translateX="3" android:translateY="0">
        <!-- 左半部分：木 (Ki) -->
        <!-- 横 -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M22,45 L42,45" />
        <!-- 竖 -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M32,25 L32,75" />
        <!-- 撇 -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M32,45 L22,65" />
        <!-- 点 (捺的变形) -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M32,45 L42,65" />

        <!-- 右半部分：攵 (Boku) -->
        <!-- 顶部的撇与横折 -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M55,30 C55,30 52,40 48,42" />
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M52,35 L75,35 L72,48" />

        <!-- 下部的撇与捺 -->
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M65,42 L52,75" />
        <path
            android:strokeColor="#3E2723"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:pathData="M55,52 C60,55 75,70 80,75" />
    </group>

</vector>