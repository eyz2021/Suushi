<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- 根容器：控制整体安全区域 -->
    <group
        android:scaleX="0.9"
        android:scaleY="0.9"
        android:pivotX="50"
        android:pivotY="50">

        <!-- 寿司主体与算盘：增大尺寸并整体上移 -->
        <group
            android:scaleX="1.15"
            android:scaleY="1.15"
            android:pivotX="50"
            android:pivotY="50"
            android:translateY="-8">

            <!-- 1. 软糯米饭 (Rice Base) -->
            <path
                android:fillColor="#FFFFFF"
                android:pathData="M30,50 C25,50 22,55 22,60 C22,68 28,72 50,72 C72,72 78,68 78,60 C78,55 75,50 70,50 Z" />

            <!-- 2. 三文鱼盖片 (Salmon Topping) -->
            <path
                android:fillColor="#FF9E80"
                android:pathData="M25,48 C25,35 35,28 50,28 C65,28 75,35 75,48 C75,52 70,55 50,55 C30,55 25,52 25,48 Z" />

            <!-- 装饰条纹 -->
            <path
                android:strokeColor="#FFCCBC"
                android:strokeWidth="2"
                android:strokeLineCap="round"
                android:pathData="M35,35 C40,32 50,32 55,35" />
            <path
                android:strokeColor="#FFCCBC"
                android:strokeWidth="2"
                android:strokeLineCap="round"
                android:pathData="M30,42 C40,38 60,38 70,42" />

            <!-- 3. 拟人化表情 (Face) -->
            <path android:fillColor="#3E2723" android:pathData="M43,62 A2,2 0 1,1 43,58 A2,2 0 1,1 43,62 Z" />
            <path android:fillColor="#3E2723" android:pathData="M57,62 A2,2 0 1,1 57,58 A2,2 0 1,1 57,62 Z" />
            <path
                android:strokeColor="#3E2723"
                android:strokeWidth="1.2"
                android:strokeLineCap="round"
                android:pathData="M48,65 Q50,67 52,65" />
            <path android:fillColor="#FFCDD2" android:pathData="M38,65 A3,3 0 1,1 38,59 A3,3 0 1,1 38,65 Z" />
            <path android:fillColor="#FFCDD2" android:pathData="M62,65 A3,3 0 1,1 62,59 A3,3 0 1,1 62,65 Z" />

            <!-- 4. 迷你算盘 (Abacus) -->
            <group android:translateX="62" android:translateY="55">
                <path
                    android:fillColor="#FFAB91"
                    android:pathData="M2,2 L14,2 Q16,2 16,4 L16,12 Q16,14 14,14 L2,14 Q0,14 0,12 L0,4 Q0,2 2,2 Z" />
                <path android:fillColor="#BF360C" android:pathData="M3,5 L5,5 L5,7 L3,7 Z M3,9 L5,9 L5,11 L3,11 Z" />
                <path android:fillColor="#BF360C" android:pathData="M7,5 L9,5 L9,7 L7,7 Z M7,9 L11,9 L11,11 L7,11 Z" />
                <path android:fillColor="#BF360C" android:pathData="M11,5 L13,5 L13,7 L11,7 Z M11,9 L13,9 L13,11 L11,11 Z" />
            </group>
        </group>

        <!-- 5. 底部文字：suushi (缩小并上移，在底部平铺) -->
        <group
            android:scaleX="0.75"
            android:scaleY="0.75"
            android:pivotX="50"
            android:pivotY="50"
            android:translateX="2"
            android:translateY="57">
            <group android:translateX="10">
                <!-- s -->
                <path
                    android:strokeColor="#FF9E80"
                    android:strokeWidth="3.5"
                    android:strokeLineCap="round"
                    android:pathData="M5,2 C2,2 1,3 1,5 C1,8 6,7 6,10 C6,12 5,13 2,13" />
                <!-- u -->
                <group android:translateX="12">
                    <path
                        android:strokeColor="#FF9E80"
                        android:strokeWidth="3.5"
                        android:strokeLineCap="round"
                        android:pathData="M2,4 L2,10 Q2,13 5,13 Q8,13 8,10 L8,4" />
                </group>
                <!-- u -->
                <group android:translateX="26">
                    <path
                        android:strokeColor="#FF9E80"
                        android:strokeWidth="3.5"
                        android:strokeLineCap="round"
                        android:pathData="M2,4 L2,10 Q2,13 5,13 Q8,13 8,10 L8,4" />
                </group>
                <!-- s -->
                <group android:translateX="40">
                    <path
                        android:strokeColor="#FF9E80"
                        android:strokeWidth="3.5"
                        android:strokeLineCap="round"
                        android:pathData="M5,2 C2,2 1,3 1,5 C1,8 6,7 6,10 C6,12 5,13 2,13" />
                </group>
                <!-- h -->
                <group android:translateX="54">
                    <path
                        android:strokeColor="#FF9E80"
                        android:strokeWidth="3.5"
                        android:strokeLineCap="round"
                        android:pathData="M2,1 L2,13 M2,7 Q7,7 7,10 L7,13" />
                </group>
                <!-- i -->
                <group android:translateX="68">
                    <path
                        android:strokeColor="#FF9E80"
                        android:strokeWidth="3.5"
                        android:strokeLineCap="round"
                        android:pathData="M3,5 L3,13 M3,1 L3,2" />
                </group>
            </group>
        </group>
    </group>

    <!-- 装饰性的小芝麻 -->
    <path android:fillColor="#E0E0E0" android:pathData="M40,30 A1,1 0 1,1 40,28 A1,1 0 1,1 40,30 Z" />
    <path android:fillColor="#E0E0E0" android:pathData="M60,30 A1,1 0 1,1 60,28 A1,1 0 1,1 60,30 Z" />
    <path android:fillColor="#E0E0E0" android:pathData="M50,27 A1,1 0 1,1 50,25 A1,1 0 1,1 50,27 Z" />

</vector>